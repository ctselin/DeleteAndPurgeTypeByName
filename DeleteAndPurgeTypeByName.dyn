        }
      ],
      "Replication": "Disabled",
      "Description": "Creates a string.",
      "InputValue": "Ben"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\nclr.AddReference('RevitAPI')\r\nfrom Autodesk.Revit.DB import *\r\n\r\nclr.AddReference('RevitServices')\r\nimport RevitServices\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\ninput_names = UnwrapElement(IN[0])\r\nif not isinstance(input_names, list):\r\n    input_names = [input_names]\r\n    \r\ninput_names = [str(n).strip().lower() for n in input_names if n]\r\n\r\ndeleted_elements_count = 0\r\nerrors = []\r\nfound_names = []\r\n\r\nTransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\ntypes = FilteredElementCollector(doc).WhereElementIsElementType().ToElements()\r\ninstances = FilteredElementCollector(doc).WhereElementIsNotElementType().ToElements()\r\nall_elems = list(types) + list(instances)\r\n\r\nelements_to_delete = []\r\nfor e in all_elems:\r\n    try:\r\n        if not e.IsValidObject:\r\n            continue\r\n        if not hasattr(e, \"Name\") or not e.Name:\r\n            continue\r\n            \r\n        e_name = e.Name.strip().lower()\r\n        for search_name in input_names:\r\n            if search_name == e_name:\r\n                elements_to_delete.append(e)\r\n                found_names.append(e.Name)\r\n            elif search_name in e_name and len(search_name) > 2:\r\n                hint = \"Hint: Found '\" + e.Name + \"'\"\r\n                if hint not in errors:\r\n                    errors.append(hint)\r\n    except:\r\n        pass\r\n\r\nif not elements_to_delete:\r\n    errors.append(\"ERROR: Could not find any exact match for your input.\")\r\n\r\nfor elem in elements_to_delete:\r\n    try:\r\n        # Extremely safe verification to prevent InvalidObjectException\r\n        if not elem.IsValidObject:\r\n            continue\r\n            \r\n        doc.Delete(elem.Id)\r\n        deleted_elements_count += 1\r\n    except Exception as e:\r\n        pass\r\n\r\nTransactionManager.Instance.TransactionTaskDone()\r\n\r\nOUT = [\r\n    \"SUCCESS! Items destroyed: \" + str(deleted_elements_count),\r\n    \"Destroyed Names: \" + str(found_names),\r\n    \"Hints log: \" + str(errors)\r\n]",
