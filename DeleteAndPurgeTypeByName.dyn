  "Description": "Deletes and purges specific element types by their string Name",
  "Name": "DeleteAndPurgeTypeByName",
  "ElementResolver": {
    "ResolutionMap": {}
  },
  "Inputs": [],
  "Outputs": [],
  "Nodes": [
    {
      "ConcreteType": "CoreNodeModels.Input.StringInput, CoreNodeModels",
      "SerializedWidth": 0.0,
      "SerializedHeight": 0.0,
      "Id": "ec8c5e97518340aba3991a320de0584d",
